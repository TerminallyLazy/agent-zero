# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OLLAMA_API_BASE=http://localhost:11434
# TOGETHER_API_KEY=your_together_api_key_here
# AZURE_API_KEY=your_azure_api_key_here
# AZURE_API_BASE=your_azure_endpoint_here

# Model Configuration
# Uncomment to override defaults
# CHAT_MODEL_PROVIDER=openai
# CHAT_MODEL_NAME=gpt-4o
# UTILITY_MODEL_PROVIDER=openai
# UTILITY_MODEL_NAME=gpt-3.5-turbo

# Advanced Model Configuration
# CHAT_MODEL_CTX_LENGTH=128000
# UTILITY_MODEL_CTX_LENGTH=16000
# CHAT_MODEL_TEMPERATURE=0.7
# UTILITY_MODEL_TEMPERATURE=0.2

# MCP Configuration
# MCP_ENABLED=true
# MCP_SERVERS=http://localhost:8000,http://localhost:8001

# Logging Configuration
# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FILE=agent_zero_lite.log

# Memory Configuration
# MEMORY_DIR=./memory
# DEFAULT_MEMORY_AREA=main

# Extension Configuration
# EXTENSIONS_ENABLED=true
# EXTENSION_DIRS=./extensions,/path/to/custom/extensions