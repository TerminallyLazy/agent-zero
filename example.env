# ============================================================================
# 🔐 SECURITY NOTICE: Enhanced Secrets Management (v0.8.6+)
# ============================================================================
# 
# Agent Zero now supports secure credential management using placeholder 
# substitution. This prevents sensitive data from appearing in logs, prompts,
# or the front-end interface.
#
# SETUP OPTIONS:
#
# Option 1 (RECOMMENDED): Use Placeholder System
# ──────────────────────────────────────────────
# 1. Set placeholders here:     API_KEY_OPENAI=§§API_KEY_OPENAI§§
# 2. Add real values to:        /tmp/secrets.env
# 3. Set permissions:           chmod 600 /tmp/secrets.env
# 4. Use in conversations:      "Use API key §§API_KEY_OPENAI§§"
#
# Option 2 (LEGACY): Direct Values  
# ─────────────────────────────────
# 1. Set real values here:      API_KEY_OPENAI=sk-your-actual-key
# 2. Secure this file:          chmod 600 .env
# 3. Never commit to git:       Add .env to .gitignore
#
# SECURITY BENEFITS of Placeholder System:
# • Real credentials never appear in chat logs or UI
# • Automatic substitution at runtime for tools
# • Centralized credential management
# • Easy rotation and environment separation
#
# For setup help, see: docs/secrets-user-guide.md
# ============================================================================

# API Keys - Use placeholders (§§SECRET_NAME§§) for secure management
API_KEY_OPENAI=§§API_KEY_OPENAI§§
API_KEY_ANTHROPIC=§§API_KEY_ANTHROPIC§§
API_KEY_GROQ=§§API_KEY_GROQ§§
API_KEY_PERPLEXITY=§§API_KEY_PERPLEXITY§§
API_KEY_GOOGLE=§§API_KEY_GOOGLE§§
API_KEY_MISTRAL=§§API_KEY_MISTRAL§§
API_KEY_OPENROUTER=§§API_KEY_OPENROUTER§§
API_KEY_SAMBANOVA=§§API_KEY_SAMBANOVA§§
API_KEY_CHUTES=§§API_KEY_CHUTES§§
API_KEY_DEEPSEEK=§§API_KEY_DEEPSEEK§§
API_KEY_HUGGINGFACE=§§API_KEY_HUGGINGFACE§§

# Azure OpenAI Configuration
API_KEY_OPENAI_AZURE=§§API_KEY_OPENAI_AZURE§§
OPENAI_AZURE_ENDPOINT=§§OPENAI_AZURE_ENDPOINT§§
OPENAI_API_VERSION=2024-02-15-preview

# Other Tokens
HF_TOKEN=§§HF_TOKEN§§

# Web UI Configuration
WEB_UI_PORT=50001
USE_CLOUDFLARE=false

# Authentication (use placeholders for security)
AUTH_LOGIN=§§AUTH_LOGIN§§
AUTH_PASSWORD=§§AUTH_PASSWORD§§
ROOT_PASSWORD=§§ROOT_PASSWORD§§

# Remote Function Call Configuration
RFC_PASSWORD=§§RFC_PASSWORD§§

# Model Provider Base URLs (usually don't need to change)
OLLAMA_BASE_URL="http://127.0.0.1:11434"
LM_STUDIO_BASE_URL="http://127.0.0.1:1234/v1"
OPEN_ROUTER_BASE_URL="https://openrouter.ai/api/v1"
SAMBANOVA_BASE_URL="https://fast-api.snova.ai/v1"

# System Configuration
TOKENIZERS_PARALLELISM=true
PYDEVD_DISABLE_FILE_VALIDATION=1

# ============================================================================
# 📁 EXAMPLE /tmp/secrets.env FILE CONTENT:
# ============================================================================
# Copy this to /tmp/secrets.env and add your real credentials:
#
# # System passwords
# ROOT_PASSWORD=your_root_password_here
# AUTH_LOGIN=your_username_here
# AUTH_PASSWORD=your_web_ui_password_here
# RFC_PASSWORD=your_rfc_password_here
#
# # API Keys
# API_KEY_OPENAI=sk-your-openai-key-here
# API_KEY_ANTHROPIC=sk-ant-your-anthropic-key-here
# API_KEY_GOOGLE=your-google-api-key-here
# # ... add other API keys as needed
#
# Remember: chmod 600 /tmp/secrets.env
# ============================================================================
